#include<stdio.h>
#define MAX 10

int n, e, adj[MAX][MAX], visited[MAX];

void createGraph() {
    int i, u, v;
    printf("Enter vertices: "); scanf("%d", &n);
    printf("Enter edges: ");    scanf("%d", &e);
    for(i = 0; i < e; i++) {
        printf("Edge (u v): "); scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        adj[v][u] = 1;
    }
}

void DFS(int v) {
    int i;
    visited[v] = 1;
    printf("%d ", v);
    for(i = 1; i <= n; i++) {
        if(adj[v][i] == 1 && !visited[i])
            DFS(i);
    }
}

int main() {
    int s;
    createGraph();
    printf("Enter start vertex: "); scanf("%d", &s);
    printf("DFS: ");
    DFS(s);
    printf("\n");
    return 0;
}
