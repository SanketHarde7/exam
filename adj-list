#include<stdio.h>
#include<stdlib.h>
#define MAX 10

struct Node {
    int data;
    struct Node *next;
};

struct Node *adj[MAX];
int n, e;

void addEdge(int u, int v) {
    struct Node *newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = v;
    newNode->next = adj[u];
    adj[u] = newNode;
}

void createGraph() {
    int i, u, v;
    printf("Enter vertices: "); scanf("%d", &n);
    printf("Enter edges: ");    scanf("%d", &e);
    for(i = 0; i < e; i++) {
        printf("Edge (u v): "); scanf("%d %d", &u, &v);
        addEdge(u, v);
        addEdge(v, u);
    }
}

void displayList() {
    int i;
    struct Node *temp;
    printf("\nAdjacency List:\n");
    for(i = 1; i <= n; i++) {
        printf("%d -> ", i);
        temp = adj[i];
        while(temp) { printf("%d ", temp->data); temp = temp->next; }
        printf("NULL\n");
    }
}

void calcDegree() {
    int i;
    struct Node *temp;
    printf("\nVertex  Degree\n");
    for(i = 1; i <= n; i++) {
        int deg = 0;
        temp = adj[i];
        while(temp) { deg++; temp = temp->next; }
        printf("  %d       %d\n", i, deg);
    }
}

int main() {
    createGraph();
    displayList();
    calcDegree();
    return 0;
}
