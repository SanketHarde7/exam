#include<stdio.h>
#define MAX 10

int n, e, adj[MAX][MAX], indegree[MAX];

void createGraph() {
    int i, u, v;
    printf("Enter vertices: "); scanf("%d", &n);
    printf("Enter edges: ");    scanf("%d", &e);
    for(i = 0; i < e; i++) {
        printf("Directed edge (u -> v): "); scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        indegree[v]++;
    }
}

void topoSort() {
    int queue[MAX], front = 0, rear = 0;
    int i, v, count = 0;

    for(i = 1; i <= n; i++)
        if(indegree[i] == 0) queue[rear++] = i;

    printf("Topological Order: ");
    while(front < rear) {
        v = queue[front++];
        printf("%d ", v);
        count++;
        for(i = 1; i <= n; i++) {
            if(adj[v][i]) {
                indegree[i]--;
                if(indegree[i] == 0) queue[rear++] = i;
            }
        }
    }
    if(count != n) printf("\nCycle detected!");
    printf("\n");
}

int main() {
    createGraph();
    topoSort();
    return 0;
}
