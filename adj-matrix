#include<stdio.h>
#define MAX 10

int n, e, adj[MAX][MAX];

void createGraph() {
    int i, u, v;
    printf("Enter number of vertices: ");
    scanf("%d", &n);
    printf("Enter number of edges: ");
    scanf("%d", &e);
    for(i = 0; i < e; i++) {
        printf("Enter edge (u v): ");
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;
        adj[v][u] = 1;
    }
}

void displayMatrix() {
    int i, j;
    printf("\nAdjacency Matrix:\n");
    for(i = 1; i <= n; i++) {
        for(j = 1; j <= n; j++)
            printf("%d ", adj[i][j]);
        printf("\n");
    }
}

void calcDegree() {
    int i, j, in, out;
    printf("\nVertex  Indegree  Outdegree  Totaldegree\n");
    for(i = 1; i <= n; i++) {
        in = 0; out = 0;
        for(j = 1; j <= n; j++) {
            out += adj[i][j];
            in  += adj[j][i];
        }
        printf("  %d       %d         %d          %d\n", i, in, out, in+out);
    }
}
int main() {
    createGraph();
    displayMatrix();
    calcDegree();
    return 0;
}
